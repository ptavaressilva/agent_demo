# Copy to .env and fill in. Every var has a sensible local-dev default
# (agent_demo/platform/config.py for deployment/ops settings, each
# agent_demo/agents/<agent>/config.py for that agent's own settings) except
# ANTHROPIC_API_KEY and LLM_GATEWAY_API_KEY, which are required.

# --- Which agent this process serves ---
# One of the ids registered in agent_demo/platform/registry.py. Defaults to
# house-search if unset.
AGENT_ID=house-search

# === Platform / deployment settings (agent_demo/platform/config.py) ===
# Apply to every agent regardless of AGENT_ID.

# --- LLM gateway (LiteLLM proxy, see litellm_config.yaml) ---
# Every agent talks only to the gateway (LLM_GATEWAY_BASE_URL) and
# authenticates with LLM_GATEWAY_API_KEY -- pick any value, it just has to
# match the LiteLLM proxy's LITELLM_MASTER_KEY (docker-compose.yml passes
# this same var through). ANTHROPIC_API_KEY is read by the gateway container
# only; no agent process ever sees it.
ANTHROPIC_API_KEY=
LLM_GATEWAY_BASE_URL=http://localhost:4000
LLM_GATEWAY_API_KEY=

# --- MongoDB: short-term (checkpointer), long-term (store), factual memory, kill switch ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_demo

# --- Arize AX tracing ---
ARIZE_SPACE_ID=
ARIZE_API_KEY=
TRACING_ENABLED=true

# --- Budget ceilings ---
# Hard caps no agent's own default, or a caller's per-request override, can
# exceed. See agent_demo/platform/budget.py.
MAX_REACT_STEPS_CEILING=30
MAX_SELF_CORRECTION_RETRIES_CEILING=5
RECURSION_LIMIT_MULTIPLIER=4

# --- Kill switch ---
# Shared secret for POST/GET /admin/kill-switch (X-Admin-Token header). Left
# unset by default so the endpoint fails closed until you deliberately set it.
KILL_SWITCH_ADMIN_TOKEN=

# === house-search agent settings (agent_demo/agents/house_search/config.py) ===

PRIMARY_MODEL=claude-opus-4-8
FALLBACK_MODEL=claude-haiku-4-5
MAX_REACT_STEPS=12
MAX_SELF_CORRECTION_RETRIES=2

# --- Postgres: house listings, ratings, viewing requests ---
POSTGRES_DSN=postgresql://agent_demo:agent_demo@localhost:5432/agent_demo

# --- MCP servers (web search + page fetch) ---
# Default wires up the reference Brave Search MCP server over stdio; swap
# for Exa/Tavily/your own server by changing command+args.
MCP_WEB_SEARCH_COMMAND=npx
MCP_WEB_SEARCH_ARGS=-y @modelcontextprotocol/server-brave-search
BRAVE_API_KEY=
MCP_FETCH_COMMAND=uvx
MCP_FETCH_ARGS=mcp-server-fetch

# === faq-agent settings (agent_demo/agents/faq_agent/config.py) ===

FAQ_AGENT_PRIMARY_MODEL=claude-opus-4-8
FAQ_AGENT_FALLBACK_MODEL=claude-haiku-4-5
FAQ_AGENT_MAX_REACT_STEPS=4
FAQ_AGENT_MAX_SELF_CORRECTION_RETRIES=1
