# Copy to .env and fill in. Every var has a sensible local-dev default in
# agent_demo/config.py except ANTHROPIC_API_KEY, which is required.

# --- Anthropic ---
ANTHROPIC_API_KEY=
PRIMARY_MODEL=claude-opus-4-8
FALLBACK_MODEL=claude-haiku-4-5

# --- MongoDB: short-term (checkpointer), long-term (store), factual memory ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_demo

# --- Postgres: job offers, ratings, application drafts ---
POSTGRES_DSN=postgresql://agent_demo:agent_demo@localhost:5432/agent_demo

# --- MCP servers (web search + page fetch) ---
# Default wires up the reference Brave Search MCP server over stdio; swap
# for Exa/Tavily/your own server by changing command+args.
MCP_WEB_SEARCH_COMMAND=npx
MCP_WEB_SEARCH_ARGS=-y @modelcontextprotocol/server-brave-search
BRAVE_API_KEY=
MCP_FETCH_COMMAND=uvx
MCP_FETCH_ARGS=mcp-server-fetch

# --- Arize AX tracing ---
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=job-search-agent
TRACING_ENABLED=true

# --- Agent behavior ---
MAX_REACT_STEPS=12
MAX_SELF_CORRECTION_RETRIES=2
